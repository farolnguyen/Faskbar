<Window x:Class="FaskBar.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FaskBar.App"
        mc:Ignorable="d"
        Title="FaskBar Icon List Overlay (M1.2)"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#FF202020"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Width"
        Height="48">
    <Window.Resources>
        <DataTemplate x:Key="PinnedIconTemplate">
            <Button Width="44" Height="48"
                    Background="Transparent" BorderThickness="0"
                    Click="PinnedIconButton_Click"
                    PreviewMouseLeftButtonDown="PinnedButton_PreviewMouseDown"
                    PreviewMouseMove="PinnedButton_PreviewMouseMove"
                    AllowDrop="True"
                    DragOver="PinnedButton_DragOver"
                    Drop="PinnedButton_Drop"
                    Tag="{Binding DragAppId}"
                    ToolTip="{Binding DisplayName}">
                <Grid>
                    <Image Source="{Binding Icon}" Width="24" Height="24"
                           Visibility="{Binding SingleIconVisibility}" />

                    <Border Visibility="{Binding GroupVisibility}"
                            Width="28" Height="28" CornerRadius="6" Background="#40FFFFFF">
                        <Grid Margin="3">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Row="0" Grid.Column="0" Source="{Binding CollageIcon0}" Margin="0.5" />
                            <Image Grid.Row="0" Grid.Column="1" Source="{Binding CollageIcon1}" Margin="0.5" />
                            <Image Grid.Row="1" Grid.Column="0" Source="{Binding CollageIcon2}" Margin="0.5" />
                            <Image Grid.Row="1" Grid.Column="1" Source="{Binding CollageIcon3}" Margin="0.5" />
                        </Grid>
                    </Border>

                    <Border Visibility="{Binding ExtraCountBadgeVisibility}"
                            Background="#CC000000" CornerRadius="6"
                            Width="14" Height="14"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding ExtraCountText}" FontSize="9" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="RunningIconTemplate">
            <Button Width="44" Height="48"
                    Background="Transparent" BorderThickness="0"
                    Click="RunningIconButton_Click"
                    Tag="{Binding AppId}"
                    ToolTip="{Binding DisplayName}">
                <Grid>
                    <Border Background="#33FFFFFF" CornerRadius="4"
                            Visibility="{Binding IsForegroundVisibility}" />
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="{Binding Icon}" Width="24" Height="24" />
                        <Ellipse Width="6" Height="6" Margin="0,3,0,0" HorizontalAlignment="Center"
                                 Fill="{Binding DotBrush}" />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <StackPanel Orientation="Horizontal">
        <ItemsControl x:Name="PinnedItemsControl" ItemTemplate="{StaticResource PinnedIconTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <Border Width="1" Margin="4,10" Background="#33FFFFFF" />

        <ItemsControl x:Name="RunningItemsControl" ItemTemplate="{StaticResource RunningIconTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </StackPanel>
</Window>
